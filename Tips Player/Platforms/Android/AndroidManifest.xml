<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="gh.websitedesignerghana.tipsplayer">
  <!-- Required permissions -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <!-- Required on Android 14+ to start a foreground service of type mediaPlayback -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
  <!-- Android 13+ granular media permissions -->
  <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
  <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
  <!-- Android 14+ requires this for partial media access fallback -->
  <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

  <application android:allowBackup="true"
               android:icon="@android:drawable/ic_media_play"
               android:supportsRtl="true"
               android:label="Tips Player">

    <!-- Foreground media playback service (keep alive when app is backgrounded) -->
    <service android:name="gh.websitedesignerghana.tipsplayer.MediaPlaybackService"
             android:foregroundServiceType="mediaPlayback"
             android:exported="false"/>

    <!-- Broadcast receiver for notification play/pause/skip actions -->
    <receiver android:name="gh.websitedesignerghana.tipsplayer.MediaActionReceiver"
              android:exported="false">
        <intent-filter>
            <action android:name="gh.websitedesignerghana.tipsplayer.PLAY_PAUSE"/>
            <action android:name="gh.websitedesignerghana.tipsplayer.NEXT"/>
            <action android:name="gh.websitedesignerghana.tipsplayer.PREV"/>
            <action android:name="gh.websitedesignerghana.tipsplayer.STOP"/>
        </intent-filter>
    </receiver>

  </application>
</manifest>
